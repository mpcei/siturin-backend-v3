APP_PORT=3000
FRONTEND_URL=http://localhost:4200
APP_NAME='Sistema de ...'
APP_SHORT_NAME='Sistema'
APP_VERSION='1.0.0'
APP_ENV=local

JWT_SECRET=ABC
JWT_REFRESH_SECRET=XYZ
JWT_EXPIRES='1h' #'10s' | '15m' | '1h' | '7d', tiempo de expiración del token
JWT_REFRESH_EXPIRES='7d' #'10s' | '15m' | '1h' | '7d', tiempo de expiración del refresh token

MAX_ATTEMPTS='5' #numero de intentos para que se bloque el usuario
SECURITY_CODE_EXPIRES_IN='10' #tiempo de expiracion de los codigos de seguridad

THROTTLER_TTL='1m' #'10s' | '15m' | '1h' | '7d'
THROTTLER_LIMIT=100 #Es el número máximo de requests permitidos en ese tiempo, Ej. 100 peticiones por minuto

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=root

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@midominio.com
MAIL_FROM_NAME="${APP_NAME}"

