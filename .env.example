MAIL_FROM_ADDRESS=noreply@midominio.com
MAIL_FROM_NAME="${APP_NAME}"

BUCKET_ENDPOINT=http://localhost
BUCKET_PORT=8333
BUCKET_ACCESS_KEY=admin
BUCKET_SECRET_KEY=root1234
BUCKET_NAME=my_bucket
BUCKET_PRESIGNED_EXPIRY='5' #tiempo de expiracion del archivo en minutos
